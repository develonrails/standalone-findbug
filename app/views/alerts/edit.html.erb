<h1>Edit Alert Channel</h1>
<p class="page-description">Update configuration for <strong><%= @channel.name %></strong>.</p>

<div class="card" style="max-width: 560px;">
  <div class="card-content">
    <%= form_tag alert_path(@channel), method: :patch do %>
      <div style="display: flex; flex-direction: column; gap: 1.5rem;">
        <div class="form-group">
          <label>Channel Type</label>
          <div style="display: flex; align-items: center; gap: 0.5rem; height: 2rem;">
            <span class="badge badge-info"><%= @channel.display_type %></span>
            <span class="form-hint">Cannot be changed after creation</span>
          </div>
          <input type="hidden" name="alert_channel[channel_type]" value="<%= @channel.channel_type %>">
        </div>
        <div class="form-group">
          <label>Name</label>
          <input type="text" name="alert_channel[name]" value="<%= @channel.name %>" placeholder="e.g., Production Slack">
        </div>
        <label style="display: flex; align-items: center; gap: 0.75rem; cursor: pointer;">
          <input type="hidden" name="alert_channel[enabled]" value="0">
          <span class="toggle"><input type="checkbox" name="alert_channel[enabled]" value="1" <%= "checked" if @channel.enabled? %>><span class="toggle-slider"></span></span>
          <span>Enable this channel</span>
        </label>
        <div class="separator"></div>

        <% if @channel.channel_type == "email" %>
          <h3 style="font-size: 0.875rem; font-weight: 600; margin-bottom: 1.25rem; color: hsl(var(--muted-foreground));">Email Configuration</h3>
          <div style="display: flex; flex-direction: column; gap: 1.25rem;">
            <div class="form-group"><label>Recipients</label><textarea name="config[recipients]" rows="3" class="font-mono"><%= Array(@channel.config["recipients"]).join("\n") %></textarea><span class="form-hint">One email address per line</span></div>
            <div class="form-group"><label>From Address</label><input type="text" name="config[from]" value="<%= @channel.config["from"] %>" placeholder="findbug@example.com"></div>
          </div>
        <% end %>

        <% if @channel.channel_type == "slack" %>
          <h3 style="font-size: 0.875rem; font-weight: 600; margin-bottom: 1.25rem; color: hsl(var(--muted-foreground));">Slack Configuration</h3>
          <div style="display: flex; flex-direction: column; gap: 1.25rem;">
            <div class="form-group"><label>Webhook URL</label><input type="text" name="config[webhook_url]" value="<%= @channel.config["webhook_url"] %>" class="font-mono"></div>
            <div class="form-group"><label>Channel</label><input type="text" name="config[channel]" value="<%= @channel.config["channel"] %>" placeholder="#errors"></div>
            <div class="form-group"><label>Username</label><input type="text" name="config[username]" value="<%= @channel.config["username"] %>" placeholder="Findbug"></div>
            <div class="form-group"><label>Icon Emoji</label><input type="text" name="config[icon_emoji]" value="<%= @channel.config["icon_emoji"] %>" placeholder=":bug:"></div>
          </div>
        <% end %>

        <% if @channel.channel_type == "discord" %>
          <h3 style="font-size: 0.875rem; font-weight: 600; margin-bottom: 1.25rem; color: hsl(var(--muted-foreground));">Discord Configuration</h3>
          <div style="display: flex; flex-direction: column; gap: 1.25rem;">
            <div class="form-group"><label>Webhook URL</label><input type="text" name="config[webhook_url]" value="<%= @channel.config["webhook_url"] %>" class="font-mono"></div>
            <div class="form-group"><label>Username</label><input type="text" name="config[username]" value="<%= @channel.config["username"] %>" placeholder="Findbug"></div>
            <div class="form-group"><label>Avatar URL</label><input type="text" name="config[avatar_url]" value="<%= @channel.config["avatar_url"] %>"></div>
          </div>
        <% end %>

        <% if @channel.channel_type == "webhook" %>
          <h3 style="font-size: 0.875rem; font-weight: 600; margin-bottom: 1.25rem; color: hsl(var(--muted-foreground));">Webhook Configuration</h3>
          <div style="display: flex; flex-direction: column; gap: 1.25rem;">
            <div class="form-group"><label>URL</label><input type="text" name="config[url]" value="<%= @channel.config["url"] %>" class="font-mono"></div>
            <div class="form-group"><label>HTTP Method</label><%= select_tag "config[method]", options_for_select([["POST", "POST"], ["PUT", "PUT"]], @channel.config["method"] || "POST") %></div>
            <div class="form-group"><label>Custom Headers</label><textarea name="config[headers]" rows="3" class="font-mono"><%= (@channel.config["headers"] || {}).map { |k, v| "#{k}: #{v}" }.join("\n") %></textarea><span class="form-hint">One header per line</span></div>
          </div>
        <% end %>

        <div class="separator"></div>
        <div style="display: flex; gap: 0.75rem;">
          <button type="submit" class="btn btn-primary">Update Channel</button>
          <a href="<%= alerts_path %>" class="btn btn-ghost">Cancel</a>
        </div>
      </div>
    <% end %>
  </div>
</div>
