<h1>Projects</h1>
<p class="page-description">Manage applications that send data to Findbug.</p>

<div style="display: flex; justify-content: flex-end; margin-bottom: 1rem;">
  <a href="<%= new_project_path %>" class="btn btn-primary btn-sm">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 0.375rem;"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
    New Project
  </a>
</div>

<% if @projects.any? %>
  <div class="card">
    <table class="table">
      <thead><tr><th>Name</th><th>Platform</th><th>DSN</th><th>Events</th><th></th></tr></thead>
      <tbody>
        <% @projects.each do |project| %>
          <tr>
            <td><strong><%= project.name %></strong></td>
            <td><span class="badge badge-info"><%= project.platform %></span></td>
            <td class="font-mono text-xs text-muted" style="max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"><%= project.dsn %></td>
            <td class="text-muted text-sm">
              <%= project.error_events.count %> errors, <%= project.performance_events.count %> perf
            </td>
            <td>
              <div style="display: flex; gap: 0.25rem; justify-content: flex-end;">
                <a href="<%= project_path(project) %>" class="btn-icon" title="View DSN">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                </a>
                <%= button_to project_path(project), method: :delete, class: "btn-icon destructive", title: "Delete", data: { turbo_confirm: "Delete project #{project.name}?" } do %>
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <div class="card">
    <div class="empty-state">
      <div class="empty-state-icon"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8"/><path d="M12 17v4"/></svg></div>
      <p>No projects configured yet.</p>
      <p style="margin-top: 0.75rem;"><a href="<%= new_project_path %>" class="btn btn-primary btn-sm">Create your first project</a></p>
    </div>
  </div>
<% end %>
