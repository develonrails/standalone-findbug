<h1>New Project</h1>
<p class="page-description">Create a new project to start receiving error and performance data.</p>

<div class="card" style="max-width: 560px;">
  <div class="card-content">
    <%= form_tag projects_path, method: :post do %>
      <div style="display: flex; flex-direction: column; gap: 1.5rem;">
        <div class="form-group">
          <label>Project Name</label>
          <input type="text" name="project[name]" placeholder="e.g., bynqo, my-other-app" required>
          <span class="form-hint">A unique name for this application</span>
        </div>
        <div class="form-group">
          <label>Platform</label>
          <%= select_tag "project[platform]", options_for_select([["Ruby", "ruby"], ["Python", "python"], ["JavaScript", "javascript"], ["Other", "other"]]) %>
        </div>
        <div class="separator"></div>
        <div style="display: flex; gap: 0.75rem;">
          <button type="submit" class="btn btn-primary">Create Project</button>
          <a href="<%= projects_path %>" class="btn btn-ghost">Cancel</a>
        </div>
      </div>
    <% end %>
  </div>
</div>
